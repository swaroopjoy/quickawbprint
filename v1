// 3. FRONTEND (React - PRODUCTION INPUT HANDLER)
// =====================================

// src/App.jsx

import { useEffect, useState } from 'react';
import axios from 'axios';
import { invoke } from '@tauri-apps/api/tauri';

export default function App() {
  const [logs, setLogs] = useState([]);
  const [buffer, setBuffer] = useState('');
  let timeout = null;

  useEffect(() => {
    fetchLogs();

    const handleKey = (e) => {
      if (timeout) clearTimeout(timeout);

      if (e.key === 'Enter') {
        processScan(buffer);
        setBuffer('');
        return;
      }

      setBuffer(prev => prev + e.key);

      timeout = setTimeout(() => {
        setBuffer('');
      }, 100);
    };

    window.addEventListener('keydown', handleKey);
    return () => window.removeEventListener('keydown', handleKey);
  }, [buffer]);

  const fetchLogs = async () => {
    const res = await axios.get('http://localhost:3001/logs');
    setLogs(res.data);
  };

  const processScan = async (input) => {
    try {
      const res = await axios.post('http://localhost:3001/lookup', { input });
      const { data } = res.data;

      await invoke('print_pdf', { path: data.pdf_path });

      fetchLogs();
    } catch (e) {
      console.error(e);
    }
  };

  return (
    <div style={{ padding: 20, background: '#F5F7FA', height: '100vh' }}>
      <h1 style={{ color: '#3B82F6' }}>Airway Bill Auto Printer</h1>

      <div style={{ marginBottom: 20 }}>
        <strong>Live Buffer:</strong> {buffer}
      </div>

      <table style={{ width: '100%', background: '#fff' }}>
        <thead>
          <tr>
            <th>Time</th>
            <th>Input</th>
            <th>Status</th>
            <th>Source</th>
            <th>Time(ms)</th>
          </tr>
        </thead>
        <tbody>
          {logs.map(log => (
            <tr key={log.id}>
              <td>{log.timestamp}</td>
              <td>{log.input}</td>
              <td>{log.status}</td>
              <td>{log.source}</td>
              <td>{log.processing_time}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  );
}


