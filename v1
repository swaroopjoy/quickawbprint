// file: backend/server.js

const express = require('express');
const sqlite3 = require('sqlite3').verbose();
const bodyParser = require('body-parser');
const WebSocket = require('ws');

const app = express();
app.use(bodyParser.json());

const db = new sqlite3.Database('./airway.db');

// ------------------
// DB INIT
// ------------------

db.serialize(() => {
  db.run(`CREATE TABLE IF NOT EXISTS airway_bills (
    id INTEGER PRIMARY KEY,
    order_id TEXT,
    tracking_number TEXT,
    pdf_path TEXT
  )`);

  db.run(`CREATE TABLE IF NOT EXISTS logs (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    timestamp TEXT,
    input TEXT,
    order_id TEXT,
    status TEXT,
    source TEXT,
    message TEXT,
    processing_time INTEGER
  )`);
});

// ------------------
// SIMPLE QUEUE
// ------------------

const queue = [];
let activeJobs = 0;
const MAX_CONCURRENT = 3;

async function processQueue() {
  if (queue.length === 0 || activeJobs >= MAX_CONCURRENT) return;

  const job = queue.shift();
  activeJobs++;

  try {
    await job();
  } catch (e) {
    console.error('Job failed:', e);
  }

  activeJobs--;
  processQueue();
}

function addToQueue(job) {
  queue.push(job);
  processQueue();
}

// ------------------
// LOOKUP API
// ------------------

app.post('/lookup', async (req, res) => {
  const start = Date.now();
  const { input } = req.body;

  db.get(
    `SELECT * FROM airway_bills WHERE order_id=? OR tracking_number=?`,
    [input, input],
    async (err, row) => {
      let result = row;
      let source = 'local';

      if (!row) {
        // Simulated API call
        result = {
          order_id: input,
          tracking_number: input,
          pdf_path: './sample.pdf'
        };

        source = 'api';

        db.run(
          `INSERT INTO airway_bills (order_id, tracking_number, pdf_path) VALUES (?, ?, ?)`,
          [result.order_id, result.tracking_number, result.pdf_path]
        );
      }

      const processing_time = Date.now() - start;

      res.json({ success: true, data: result, source, processing_time });
    }
  );
});

// ------------------
// LOGGING
// ------------------

function logEvent(entry) {
  db.run(
    `INSERT INTO logs (timestamp, input, order_id, status, source, message, processing_time)
     VALUES (?, ?, ?, ?, ?, ?, ?)`,
    [
      new Date().toISOString(),
      entry.input,
      entry.order_id,
      entry.status,
      entry.source,
      entry.message,
      entry.processing_time
    ]
  );
}

app.get('/logs', (req, res) => {
  db.all(`SELECT * FROM logs ORDER BY id DESC LIMIT 200`, (err, rows) => {
    res.json(rows);
  });
});

// ------------------
// WEBSOCKET (MOBILE)
// ------------------

const wss = new WebSocket.Server({ port: 8081 });

wss.on('connection', (ws) => {
  ws.on('message', (msg) => {
    const input = msg.toString();

    addToQueue(async () => {
      const start = Date.now();

      try {
        const axios = require('axios');
        const res = await axios.post('http://localhost:3001/lookup', { input });

        const { data, source } = res.data;

        // send to frontend via broadcast
        wss.clients.forEach(client => {
          if (client.readyState === 1) {
            client.send(JSON.stringify({ type: 'PRINT', payload: data }));
          }
        });

        logEvent({
          input,
          order_id: data.order_id,
          status: 'SUCCESS',
          source,
          message: 'Printed',
          processing_time: Date.now() - start
        });

      } catch (e) {
        logEvent({
          input,
          order_id: null,
          status: 'FAILED',
          source: 'unknown',
          message: e.message,
          processing_time: Date.now() - start
        });
      }
    });
  });
});

app.listen(3001, () => console.log('Backend running'));


// =====================================
// 2. TAURI (DIRECT PDF-TO-PRINTER - PRODUCTION GRADE)
// =====================================

// Uses native PDF-to-printer execution (no external viewer dependency)
// Requires platform-specific binaries

// INSTALL (IMPORTANT):
// Windows: SumatraPDF (silent CLI printing)
// Mac: cups (lp already used but enhanced flags)

// src-tauri/src/main.rs

#![cfg_attr(not(debug_assertions), windows_subsystem = "windows")]

use tauri::command;
use std::process::Command;
use std::fs;
use serde::Deserialize;

#[derive(Deserialize)]
struct PrinterConfig {
    printer_name: String,
    copies: Option<u32>
}

fn load_config() -> PrinterConfig {
    let config_str = fs::read_to_string("printer_config.json")
        .expect("Unable to read printer_config.json");

    serde_json::from_str(&config_str)
        .expect("Invalid config format")
}

#[command]
fn print_pdf(path: String) -> Result<(), String> {
    let config = load_config();
    let printer = config.printer_name;
    let copies = config.copies.unwrap_or(1);

    let result = if cfg!(target_os = "windows") {
        // Uses SumatraPDF for silent direct printing
        Command::new("SumatraPDF.exe")
            .args([
                "-print-to",
                &printer,
                "-silent",
                "-print-settings",
                &format!("{}x", copies),
                path.as_str()
            ])
            .spawn()
    } else {
        // macOS/Linux via CUPS
        Command::new("lp")
            .args([
                "-d",
                &printer,
                "-n",
                &copies.to_string(),
                "-o",
                "media=Custom.4x6in",
                "-o",
                "fit-to-page",
                path.as_str()
            ])
            .spawn()
    };

    match result {
        Ok(_) => Ok(()),
        Err(e) => Err(e.to_string())
    }
}

fn main() {
    tauri::Builder::default()
        .invoke_handler(tauri::generate_handler![print_pdf])
        .run(tauri::generate_context!())
        .expect("error running app");
}

